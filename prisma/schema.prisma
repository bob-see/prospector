generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id              String   @id @default(cuid())
  firstName       String?
  lastName        String?
  displayName     String
  primaryPhone    String?
  primaryEmail    String?
  rawNotes        String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  properties      ContactProperty[]
}

model ContactProperty {
  id              String   @id @default(cuid())
  contactId       String

  addressRaw      String
  streetNumber    String?
  streetName      String?
  streetType      String?
  suburb          String?
  postcode        String?

  relationshipType String? // owner, investor, buyer etc.
  confidenceScore  Float?

  contact         Contact @relation(fields: [contactId], references: [id])
}

model MarketListing {
  id              String   @id @default(cuid())

  status          String   // for_sale, sold, under_offer
  addressRaw      String

  streetNumber    String?
  streetName      String?
  streetType      String?
  suburb          String?

  listDate        DateTime?
  soldDate        DateTime?

  createdAt       DateTime @default(now())
}